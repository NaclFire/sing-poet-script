{
  "log": {
    "disabled": false,
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "tag": "google-tls",
        "type": "tls",
        "server": "dns.google",
        "domain_resolver": "dns-local"
      },
      {
        "tag": "dns-local",
        "type": "local"
      }
    ],
    "disable_cache": false,
    "disable_expire": false
  },
  "inbounds": [
    {
      "type": "anytls",
      "tag": "anytls-in",
      "listen": "::",
      "listen_port": 8443,
      "padding_scheme": [
        "stop=8",
        "0=30-30",
        "1=100-400",
        "2=400-500,c,500-1000,c,500-1000,c,500-1000,c,500-1000",
        "3=9-9,500-1000",
        "4=500-1000",
        "5=500-1000",
        "6=500-1000",
        "7=500-1000"
      ],
      "tls": {
        "certificate": "/etc/sing-poet/cert.crt",
        "private_key": "/etc/sing-poet/private.key"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "inbound": "anytls-in",
        "outbound": "direct"
      }
    ],
    "default_domain_resolver": {
      "server": "google-tls",
      "strategy": "prefer_ipv4"
    },
    "final": "direct",
    "auto_detect_interface": true
  }
}
