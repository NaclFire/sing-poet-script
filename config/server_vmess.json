{
    "log": {
        "disabled": false,
        "level": "info"
    },
    "dns": {
        "servers": [
            {
                "tag": "google-tls",
                "type": "tls",
                "server": "dns.google",
                "domain_resolver": "dns-local"
            },
            {
                "tag": "google-udp",
                "type": "udp",
                "server": "8.8.8.8",
                "domain_resolver": "dns-local"
            },
            {
                "tag": "dns-local",
                "type": "local"
            }
        ],
        "disable_cache": false,
        "disable_expire": false
    },
    "inbounds": [
        {
            "type": "vmess",
            "tag": "vmess-in",
            "listen": "::",
            "listen_port": 54111,
            "tcp_fast_open": false,
            "sniff": false,
            "sniff_override_destination": false,
            "proxy_protocol": false,
            "transport": {
                "type": "ws",
                "path": "/vmess"
            }
        }
    ],
    "outbounds": [
        {
            "type": "direct",
            "tag": "vmess-out"
        },
        {
            "type": "direct",
            "tag": "direct"
        }
    ],
    "route": {
        "rules": [
            {
                "protocol": "dns",
                "action": "hijack-dns"
            },
            {
                "inbound": "vmess-in",
                "outbound": "vmess-out"
            }
        ],
        "default_domain_resolver": {
            "server": "google-tls",
            "strategy": "prefer_ipv4"
        },
        "geoip": {
            "path": "/etc/sing-poet/geoip.db",
            "download_url": "https://github.com/SagerNet/sing-geoip/releases/latest/download/geoip.db",
            "download_detour": "direct"
        },
        "geosite": {
            "path": "/etc/sing-poet/geosite.db",
            "download_url": "https://github.com/SagerNet/sing-geosite/releases/latest/download/geosite.db",
            "download_detour": "direct"
        },
        "final": "direct",
        "auto_detect_interface": true
    }
}