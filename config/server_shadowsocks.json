{
  "log": {
    "disabled": false,
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "tag": "google-tls",
        "type": "tls",
        "server": "dns.google",
        "domain_resolver": "dns-local"
      },
      {
        "tag": "dns-local",
        "type": "local"
      }
    ],
    "disable_cache": false,
    "disable_expire": false
  },
  "inbounds": [
    {
      "type": "shadowsocks",
      "tag": "ss-in",
      "listen": "::",
      "listen_port": 8388,
      "method": "2022-blake3-aes-256-gcm",
      "password": "{{server_key_from_sspanel}}",
      "multiplex": {
        "enabled": false
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "inbound": "ss-in",
        "outbound": "direct"
      }
    ],
    "default_domain_resolver": {
      "server": "google-tls",
      "strategy": "prefer_ipv4"
    },
    "final": "direct",
    "auto_detect_interface": true
  }
}
